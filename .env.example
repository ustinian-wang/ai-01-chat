# 默认提供商：spark-lite | sub2api
DEFAULT_PROVIDER=spark-lite

# --- 讯飞星火 Lite（HTTP OpenAI 兼容）---
# API_KEY 可为 APIPassword，或 APIKey:APISecret（英文冒号）
PROVIDER_SPARK_LITE_LABEL=讯飞星火 Lite
PROVIDER_SPARK_LITE_API_KEY=your_spark_api_key
PROVIDER_SPARK_LITE_BASE_URL=https://spark-api-open.xf-yun.com/v1/
PROVIDER_SPARK_LITE_MODEL=lite
# 可选模型列表（逗号分隔）；不填则用内置星火模型表
# PROVIDER_SPARK_LITE_MODELS=lite,generalv3.5,4.0Ultra

# --- Sub2API 商城网关 ---
PROVIDER_SUB2API_LABEL=Sub2API 商城
PROVIDER_SUB2API_API_KEY=your_sub2api_sk_key
PROVIDER_SUB2API_BASE_URL=https://sub2api-mall.faibak.com/v1/
PROVIDER_SUB2API_MODEL=gpt-5.4-mini
# 不填 MODELS 时会自动请求 /v1/models；也可手动指定
# PROVIDER_SUB2API_MODELS=gpt-5.4-mini,gpt-5.4,gpt-5.5,glm-5.1
# PROVIDER_SUB2API_FETCH_MODELS=true

# 兼容旧版单一路由（未配置 PROVIDER_SPARK_LITE_API_KEY 时回退）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=lite

# 服务端口（与 langchain-test 默认 8001 错开）
BACKEND_PORT=8002
