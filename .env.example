# OpenAI 官方或任意 OpenAI 兼容端点（如 DashScope / 讯飞星火等）
# 讯飞星火：OPENAI_API_KEY 可为 APIPassword，或 APIKey:APISecret（英文冒号），与控制台 HTTP 产品一致
# 兼容 SDK 时 OPENAI_BASE_URL=https://spark-api-open.xf-yun.com/v1/（勿写 /chat/completions）
# 模型见文档：lite、generalv3.5、4.0Ultra、max-32k、generalv3、pro-128k 等
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# 服务端口（与 langchain-test 默认 8001 错开）
BACKEND_PORT=8002
